# Reference for Render environment variables.
# Do NOT commit real credentials. Set these in the Render dashboard.

# Database provider: "sqlite" (local) or "postgres" (production)
DATABASE_PROVIDER=postgres

# PostgreSQL connection string (from Supabase → Project Settings → Database → Connection string → URI)
# Replace the password placeholder with your actual password.
ConnectionStrings__DefaultConnection=Host=your-host.supabase.co;Database=postgres;Username=postgres.xxxx;Password=your-password;SSL Mode=Require;Trust Server Certificate=true

# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ASP.NET Core environment (controls Swagger visibility and log levels)
ASPNETCORE_ENVIRONMENT=Production
